# Configuration for the FinLedger web app's server-side proxy. These are read
# by the Vite dev proxy (vite.config.ts) and the Vercel edge function
# (api/[...path].ts) — NOT exposed to the browser bundle (no VITE_ prefix).

# Backend the proxy forwards /api requests to.
#   dev:  http://localhost:8000
#   prod: set in the Vercel dashboard to your Render URL
FINLEDGER_API_URL=http://localhost:8000

# Tenant API key, injected server-side on every request so the browser never
# holds it. Keep the real value in web/.env.local (gitignored) for dev, and in
# the Vercel dashboard (Settings → Environment Variables) for production.
FINLEDGER_API_KEY=sk_live_replace_me
